  finished_at                 DateTime?                     @db.Timestamp(3)
  created_by_admin_id         String                        @db.Uuid
  created_at                  DateTime                      @default(now()) @db.Timestamp(3)
  updated_at                  DateTime                      @db.Timestamp(3)
  user                        user                          @relation("analytics_import_jobs_created_by_admin", fields: [created_by_admin_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_import_jobs_created_by_admin_id_fkey")
  unmatched_analytics_imports unmatched_analytics_imports[]

  @@index([status, created_at], map: "analytics_import_jobs_status_created_at_idx")
  @@index([report_date], map: "analytics_import_jobs_report_date_idx")
  @@schema("icecream")
}

model unmatched_analytics_imports {
  id                   String                 @id
  upc                  String
  track_name           String?
  artist_name          String?
  album_name           String?
  country              String
  streams              Int
  pay_streams          Int
  source_file_name     String
  report_date          DateTime               @db.Timestamp(3)
  reason               String
  import_job_id        String?
  resolved             Boolean                @default(false)
  resolved_at          DateTime?              @db.Timestamp(3)
  resolved_by_admin_id String?                @db.Uuid
  resolved_release_id  String?                @db.Uuid
  created_at           DateTime               @default(now()) @db.Timestamp(3)
  import_job           analytics_import_jobs? @relation(fields: [import_job_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_import_job_id_fkey")
  user                 user?                  @relation("unmatched_analytics_imports_resolved_by_admin", fields: [resolved_by_admin_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_resolved_by_admin_id_fkey")
  release              release?               @relation("unmatched_analytics_imports_resolved_release", fields: [resolved_release_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_resolved_release_id_fkey")

  @@index([report_date], map: "unmatched_analytics_imports_report_date_idx")
  @@index([upc], map: "unmatched_analytics_imports_upc_idx")
  @@index([resolved, report_date], map: "unmatched_analytics_imports_resolved_report_date_idx")
  @@schema("icecream")
}

