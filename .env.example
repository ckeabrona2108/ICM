# Supabase (Prisma): pooled URL for app/runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Supabase (Prisma): direct URL for migrations/introspection
# If db.<project-ref>.supabase.co is unreachable from your network, temporarily set DIRECT_URL equal to DATABASE_URL.
DIRECT_URL="postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
NEXTAUTH_SECRET="replace_with_long_secret"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAILS="admin@your-domain.com"
SEED_USER_EMAIL="user@local.icm"
SEED_USER_PASSWORD="change-this-password"
SEED_ADMIN_EMAIL="admin@local.icm"
SEED_ADMIN_PASSWORD="change-this-admin-password"
S3_ENDPOINT="https://s3.example.com"
S3_REGION="us-east-1"
S3_BUCKET="icm-assets"
S3_ACCESS_KEY_ID="your_access_key"
S3_SECRET_ACCESS_KEY="your_secret_key"
YOOKASSA_SHOP_ID="your_yookassa_shop_id"
YOOKASSA_SECRET_KEY="your_yookassa_secret_key"
# Optional: if set, webhook URL must contain ?secret=<value>
YOOKASSA_WEBHOOK_SECRET="optional_webhook_secret"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
