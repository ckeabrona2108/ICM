# Supabase (Prisma): pooled URL for app/runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Supabase (Prisma): direct URL for migrations/introspection
# If db.<project-ref>.supabase.co is unreachable from your network, temporarily set DIRECT_URL equal to DATABASE_URL.
DIRECT_URL="postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
NEXTAUTH_SECRET="replace_with_long_secret"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAILS="admin@your-domain.com"
SEED_USER_EMAIL="user@local.icm"
SEED_USER_PASSWORD="change-this-password"
SEED_ADMIN_EMAIL="admin@local.icm"
SEED_ADMIN_PASSWORD="change-this-admin-password"
S3_ENDPOINT="https://s3.example.com"
S3_REGION="ru"
S3_BUCKET="icm-assets"
S3_ACCESS_KEY_ID="your_access_key"
S3_SECRET_ACCESS_KEY="your_secret_key"
YOOKASSA_SHOP_ID="your_yookassa_shop_id"
YOOKASSA_SECRET_KEY="your_yookassa_secret_key"
# Optional: if set, webhook URL must contain ?secret=<value>
YOOKASSA_WEBHOOK_SECRET="optional_webhook_secret"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
TELEGRAM_BONUS_BOT_SECRET="replace_with_long_random_secret_for_bot_to_backend_auth"
TELEGRAM_BONUS_JWT_SECRET="replace_with_long_random_secret_for_bonus_jwt_signing"
TELEGRAM_BONUS_BOT_USERNAME="icecreammusicbot"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_YANDEX_MAPS_API_KEY="replace_with_yandex_maps_javascript_api_key"
AUTH_SHOW_RESET_PREVIEW="true"
# Password reset via SMTP.BZ
SMTP_BZ_HOST="smtp.bz"
SMTP_BZ_PORT="465"
SMTP_BZ_SECURE="true"
SMTP_BZ_USER=""
SMTP_BZ_PASSWORD=""
SMTP_FROM_EMAIL="no-reply@example.com"
SMTP_FROM_NAME="ICECREAMMUSIC"
# Web Push / PWA notifications. Generate once with: npx web-push generate-vapid-keys
WEB_PUSH_SUBJECT="mailto:support@icecreammusic.net"
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
# Backward-compatible aliases (optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_SECURE=""
SMTP_USER=""
SMTP_PASS=""
# AI provider for analytics: "mistral" or "deepseek"
AI_PROVIDER="mistral"

# Mistral (primary)
MISTRAL_API_KEY="replace_with_mistral_api_key"
MISTRAL_BASE_URL="https://api.mistral.ai"
MISTRAL_MODEL="mistral-small-latest"
MISTRAL_FALLBACK_MODEL="mistral-medium-latest"

# DeepSeek (optional fallback)
DEEPSEEK_API_KEY="replace_with_deepseek_api_key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_FALLBACK_MODEL="deepseek-v4-flash"

# fal.ai (AI Studio, server-only)
FAL_KEY="replace_with_fal_api_key"
