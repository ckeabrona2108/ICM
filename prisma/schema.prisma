generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["icecream"]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model accounts {
  user_id            String    @db.Uuid
  type               String    @db.VarChar(16)
  provider           String    @db.VarChar(256)
  provider_ccount_id String    @db.VarChar(256)
  refresh_token      String?   @db.VarChar(1024)
  access_token       String?   @db.VarChar(1024)
  expires_at         DateTime? @db.Timestamp(6)
  token_type         String?   @db.VarChar(256)
  scope              String?   @db.VarChar(256)
  id_token           String?   @db.VarChar(256)
  session_state      String?   @db.VarChar(256)
  user               user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "accounts_user_id_user_id_fk")

  @@ignore
  @@schema("icecream")
}

model analytics {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @db.Uuid
  periodStart          DateTime @db.Timestamp(6)
  periodFinish         DateTime @db.Timestamp(6)
  reportFileUrl        String?
  flourishReportMarkup String
  user                 user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "analytics_userId_user_id_fk")

  @@schema("icecream")
}

model faq {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question String
  answer   String

  @@schema("icecream")
}

model news {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  content   String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  preview   String

  @@schema("icecream")
}

model partner_codes {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                 String                @unique
  label                String?
  active               Boolean               @default(true)
  coversReleasePayment Boolean               @default(true)
  maxUses              Int?
  usedCount            Int                   @default(0)
  expiresAt            DateTime?             @db.Timestamp(6)
  allowedUserId        String?               @db.Uuid
  allowedEmailDomain   String?
  notes                String?
  createdAt            DateTime              @default(now()) @db.Timestamp(6)
  updatedAt            DateTime              @updatedAt @db.Timestamp(6)
  createdByAdminId     String?               @db.Uuid
  allowedUser          user?                 @relation("partner_codes_allowed_user", fields: [allowedUserId], references: [id], onDelete: SetNull)
  createdByAdmin       user?                 @relation("partner_codes_created_by_admin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  usages               partner_code_usages[]

  @@schema("icecream")
}

model orders {
  id             String     @id @db.Uuid
  createdAt      DateTime?  @default(now()) @db.Timestamp(6)
  userId         String     @db.Uuid
  type           order_type
  metadata       Json
  confirmed      Boolean    @default(false)
  payment_status String     @default("pending_payment")
  completed_at   DateTime?  @db.Timestamp(6)
  user           user       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "orders_userId_user_id_fk")

  @@schema("icecream")
}

model payment_methods {
  id        String  @id @db.Uuid
  userId    String  @db.Uuid
  metadata  Json
  isDefault Boolean @default(false)
  user      user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "payment_methods_userId_user_id_fk")

  @@schema("icecream")
}

model payouts {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  confirmed     Boolean?  @default(false)
  recieverName  String?
  amount        Float?
  accountNumber String?
  user          user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "payouts_userId_user_id_fk")

  @@schema("icecream")
}

model promo_links {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortName  String
  releaseId  String       @db.Uuid
  release    release      @relation(fields: [releaseId], references: [id], onDelete: Cascade, map: "promo_links_releaseId_release_id_fk")
  promo_urls promo_urls[]

  @@schema("icecream")
}

model promo_urls {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url         String
  promoLinkId String?      @db.Uuid
  promo_links promo_links? @relation(fields: [promoLinkId], references: [id], onDelete: Cascade, map: "promo_urls_promoLinkId_promo_links_id_fk")

  @@schema("icecream")
}

model promo_submissions {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String   @db.Uuid
  release_id            String   @db.Uuid
  status                PromoSubmissionStatus @default(SUBMITTED)
  email                 String
  partner_name          String
  artist_name           String
  artist_country        String
  release_title         String
  release_date          DateTime @db.Timestamp(6)
  genre                 String
  release_format        String
  release_language      String
  upc                   String
  key_track_title       String
  has_music_video       Boolean  @default(false)
  video_preview_url     String?
  label                 String
  release_description   String
  artist_photo_url      String
  listening_link        String
  promotion_plan        String
  artist_social_links   String
  confirmation_accepted Boolean  @default(false)
  admin_comment         String?
  created_at            DateTime @default(now()) @db.Timestamp(6)
  updated_at            DateTime @updatedAt @db.Timestamp(6)
  reviewed_at           DateTime? @db.Timestamp(6)
  reviewed_by           String?  @db.Uuid
  user                  user     @relation("promo_submissions_user", fields: [user_id], references: [id], onDelete: Cascade)
  release               release  @relation(fields: [release_id], references: [id], onDelete: Cascade)
  reviewer              user?    @relation("promo_submissions_reviewed_by", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@unique([user_id, release_id])
  @@index([status, created_at])
  @@index([user_id, created_at])
  @@index([release_id])
  @@schema("icecream")
}

model venues {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id  String?  @db.Uuid
  name           String
  city           String?
  address        String?
  place_id       String?
  map_provider   String?
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  metadata       Json?
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)
  owner          user?    @relation("venues_owner", fields: [owner_user_id], references: [id], onDelete: SetNull)
  events         events[]

  @@index([owner_user_id, created_at])
  @@index([name])
  @@index([city])
  @@schema("icecream")
}

model events {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizer_user_id      String               @db.Uuid
  venue_id               String?              @db.Uuid
  title                  String
  slug                   String               @unique
  event_type             EventType            @default(CONCERT)
  age_restriction        EventAgeRestriction  @default(ALL_AGES)
  description            String?
  city                   String?
  venue_name             String?
  address                String?
  hashtags               String[]             @default([])
  genres                 String[]             @default([])
  starts_at              DateTime             @db.Timestamp(6)
  ends_at                DateTime?            @db.Timestamp(6)
  cover_image_url        String?
  poster_image_url       String?
  currency               String               @default("RUB")
  ticket_sales_enabled   Boolean              @default(true)
  ticket_terms           String?
  status                 EventStatus          @default(DRAFT)
  published_at           DateTime?            @db.Timestamp(6)
  moderation_note        String?
  metadata               Json?
  created_at             DateTime             @default(now()) @db.Timestamp(6)
  updated_at             DateTime             @updatedAt @db.Timestamp(6)
  organizer              user                 @relation("events_organizer", fields: [organizer_user_id], references: [id], onDelete: Cascade)
  venue                  venues?              @relation(fields: [venue_id], references: [id], onDelete: SetNull)
  tags                   event_tags[]
  artists                event_artists[]
  images                 event_images[]
  ticket_types           event_ticket_types[]
  tickets                event_tickets[]
  orders                 ticket_orders[]
  payments               ticket_payments[]
  checkins               ticket_checkins[]
  staff_access_tokens    staff_access_tokens[]
  ticket_check_logs      ticket_check_logs[]
  financial_transactions event_financial_transactions[]
  payouts                event_payouts[]

  @@index([organizer_user_id, status, starts_at])
  @@index([slug])
  @@index([venue_id])
  @@schema("icecream")
}

model event_tags {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id    String   @db.Uuid
  value       String
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  event       events   @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id, sort_order])
  @@schema("icecream")
}

model event_artists {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id         String            @db.Uuid
  artist_user_id   String?           @db.Uuid
  display_name     String
  photo_url        String?
  role             EventArtistRole   @default(ARTIST)
  performance_time String?
  sort_order       Int               @default(0)
  metadata         Json?
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  updated_at       DateTime          @updatedAt @db.Timestamp(6)
  event            events            @relation(fields: [event_id], references: [id], onDelete: Cascade)
  artist_profile   user?             @relation("event_artist_profiles", fields: [artist_user_id], references: [id], onDelete: SetNull)

  @@index([event_id, sort_order])
  @@schema("icecream")
}

model event_images {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id    String   @db.Uuid
  image_url   String
  alt_text    String?
  kind        String   @default("gallery")
  is_cover    Boolean  @default(false)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @updatedAt @db.Timestamp(6)
  event       events   @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id, sort_order])
  @@schema("icecream")
}

model event_ticket_types {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id         String              @db.Uuid
  kind             EventTicketTypeKind @default(REGULAR)
  name             String
  description      String?
  price            Decimal             @db.Decimal(14, 2)
  currency         String              @default("RUB")
  quantity_total   Int                 @default(0)
  quantity_sold    Int                 @default(0)
  per_user_limit   Int                 @default(10)
  sales_start_at   DateTime?           @db.Timestamp(6)
  sales_end_at     DateTime?           @db.Timestamp(6)
  enabled          Boolean             @default(true)
  sort_order       Int                 @default(0)
  metadata         Json?
  created_at       DateTime            @default(now()) @db.Timestamp(6)
  updated_at       DateTime            @updatedAt @db.Timestamp(6)
  event            events              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  tickets          event_tickets[]
  orders           ticket_orders[]

  @@index([event_id, sort_order])
  @@schema("icecream")
}

model ticket_orders {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id            String              @db.Uuid
  ticket_type_id      String              @db.Uuid
  buyer_user_id       String?             @db.Uuid
  order_number        String?             @unique
  status              EventPaymentStatus  @default(PENDING_PAYMENT)
  buyer_email         String
  buyer_name          String?
  buyer_phone         String?
  quantity            Int                 @default(1)
  total_amount        Decimal             @db.Decimal(14, 2)
  currency            String              @default("RUB")
  payment_provider    String?
  payment_reference   String?
  paid_at             DateTime?           @db.Timestamp(6)
  completed_at        DateTime?           @db.Timestamp(6)
  cancelled_at        DateTime?           @db.Timestamp(6)
  email_sent_at       DateTime?           @db.Timestamp(6)
  email_delivery_status String?
  provider_message_id String?
  metadata            Json?
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  event               events              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  ticket_type         event_ticket_types  @relation(fields: [ticket_type_id], references: [id], onDelete: Cascade)
  buyer               user?               @relation("ticket_orders_buyer", fields: [buyer_user_id], references: [id], onDelete: SetNull)
  tickets             event_tickets[]
  payments            ticket_payments[]
  financials          event_financial_transactions[]

  @@index([event_id, created_at])
  @@index([buyer_user_id, created_at])
  @@index([status, created_at])
  @@schema("icecream")
}

model ticket_payments {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id             String              @db.Uuid
  event_id             String              @db.Uuid
  amount               Decimal             @db.Decimal(14, 2)
  currency             String              @default("RUB")
  provider             String?
  provider_payment_id  String?
  status               EventPaymentStatus  @default(PENDING_PAYMENT)
  raw_payload          Json?
  confirmed_at         DateTime?           @db.Timestamp(6)
  created_at           DateTime            @default(now()) @db.Timestamp(6)
  updated_at           DateTime            @updatedAt @db.Timestamp(6)
  order                ticket_orders       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  event                events              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  financials           event_financial_transactions[]

  @@index([order_id, created_at])
  @@index([provider_payment_id])
  @@schema("icecream")
}

model event_tickets {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id         String             @db.Uuid
  ticket_type_id   String             @db.Uuid
  order_id         String?            @db.Uuid
  buyer_user_id    String?            @db.Uuid
  ticket_code      String             @unique
  public_token     String?            @unique
  qr_payload       String
  status           EventTicketStatus  @default(AVAILABLE)
  holder_name      String?
  buyer_email      String?
  buyer_phone      String?
  purchase_at      DateTime?          @db.Timestamp(6)
  checked_in_at    DateTime?          @db.Timestamp(6)
  checked_in_by_type String?
  checked_in_by_id String?
  used_at          DateTime?          @db.Timestamp(6)
  cancelled_at     DateTime?          @db.Timestamp(6)
  refunded_at      DateTime?          @db.Timestamp(6)
  metadata         Json?
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @updatedAt @db.Timestamp(6)
  event            events             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  ticket_type      event_ticket_types @relation(fields: [ticket_type_id], references: [id], onDelete: Cascade)
  order            ticket_orders?     @relation(fields: [order_id], references: [id], onDelete: SetNull)
  buyer            user?              @relation("event_tickets_buyer", fields: [buyer_user_id], references: [id], onDelete: SetNull)
  checkins         ticket_checkins[]
  check_logs       ticket_check_logs[]

  @@index([event_id, status, created_at])
  @@index([event_id, public_token])
  @@index([buyer_user_id, created_at])
  @@schema("icecream")
}

model staff_access_tokens {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id           String    @db.Uuid
  token_hash         String    @unique
  label              String?
  role               String    @default("staff")
  expires_at         DateTime  @db.Timestamp(6)
  revoked_at         DateTime? @db.Timestamp(6)
  created_by_user_id String    @db.Uuid
  last_used_at       DateTime? @db.Timestamp(6)
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime  @updatedAt @db.Timestamp(6)
  event              events    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  created_by         user      @relation("staff_access_tokens_created_by", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  check_logs         ticket_check_logs[]

  @@index([event_id, created_at])
  @@index([event_id, expires_at])
  @@schema("icecream")
}

model ticket_checkins {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id            String   @db.Uuid
  ticket_id           String   @db.Uuid
  checked_in_by_user_id String @db.Uuid
  method              String   @default("qr")
  gate_name           String?
  notes               String?
  created_at          DateTime @default(now()) @db.Timestamp(6)
  event               events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  ticket              event_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  actor               user     @relation("ticket_checkins_actor", fields: [checked_in_by_user_id], references: [id], onDelete: Cascade)

  @@index([event_id, created_at])
  @@index([ticket_id])
  @@schema("icecream")
}

model ticket_check_logs {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String               @db.Uuid
  ticket_id       String?              @db.Uuid
  check_mode      String
  result          String
  staff_access_id String?              @db.Uuid
  scanner_ip      String?
  user_agent      String?
  created_at      DateTime             @default(now()) @db.Timestamp(6)
  event           events               @relation(fields: [event_id], references: [id], onDelete: Cascade)
  ticket          event_tickets?       @relation(fields: [ticket_id], references: [id], onDelete: SetNull)
  staff_access    staff_access_tokens? @relation(fields: [staff_access_id], references: [id], onDelete: SetNull)

  @@index([event_id, created_at])
  @@index([ticket_id, created_at])
  @@index([staff_access_id, created_at])
  @@schema("icecream")
}

model event_financial_transactions {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id             String                 @db.Uuid
  organizer_user_id    String                 @db.Uuid
  order_id             String?                @db.Uuid
  payment_id           String?                @db.Uuid
  payout_id            String?                @db.Uuid
  direction            EventFinancialDirection
  gross_amount         Decimal                @db.Decimal(14, 2)
  commission_amount    Decimal                @default(0) @db.Decimal(14, 2)
  net_amount           Decimal                @db.Decimal(14, 2)
  currency             String                 @default("RUB")
  description          String?
  metadata             Json?
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  event                events                 @relation(fields: [event_id], references: [id], onDelete: Cascade)
  organizer            user                   @relation("event_financial_transactions_organizer", fields: [organizer_user_id], references: [id], onDelete: Cascade)
  order                ticket_orders?         @relation(fields: [order_id], references: [id], onDelete: SetNull)
  payment              ticket_payments?       @relation(fields: [payment_id], references: [id], onDelete: SetNull)
  payout               event_payouts?         @relation(fields: [payout_id], references: [id], onDelete: SetNull)

  @@index([organizer_user_id, created_at])
  @@index([event_id, created_at])
  @@schema("icecream")
}

model event_payouts {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizer_user_id   String              @db.Uuid
  event_id            String?             @db.Uuid
  status              EventPaymentStatus  @default(PENDING_PAYMENT)
  amount              Decimal             @db.Decimal(14, 2)
  currency            String              @default("RUB")
  method              String?
  notes               String?
  requested_at        DateTime            @default(now()) @db.Timestamp(6)
  paid_at             DateTime?           @db.Timestamp(6)
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  organizer           user                @relation("event_payouts_organizer", fields: [organizer_user_id], references: [id], onDelete: Cascade)
  event               events?             @relation(fields: [event_id], references: [id], onDelete: SetNull)
  financials          event_financial_transactions[]

  @@index([organizer_user_id, requested_at])
  @@schema("icecream")
}

model release {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  preview                      String
  title                        String
  date                         DateTime                       @db.Timestamp(6)
  upc                          String?
  userId                       String                         @db.Uuid
  language                     String
  subtitle                     String?
  performer                    String?
  feat                         String?
  remixer                      String?
  genre                        String
  labelName                    String?
  startDate                    DateTime                       @db.Timestamp(6)
  preorderDate                 DateTime                       @db.Timestamp(6)
  platforms                    Json?
  area                         Json?
  type                         release_type
  confirmed                    Boolean                        @default(false)
  rejectReason                 String?
  status                       verification_status            @default(moderating)
  roles                        Json?
  moderatorComment             String?
  earlyStartInRussia           Boolean?
  realTimeDelivery             Boolean?
  yandexSoonNewRelease         DateTime?                      @db.Timestamp(6)
  analytics_daily_summaries    analytics_daily_summaries[]
  analytics_platform_summaries analytics_platform_summaries[]
  analytics_report_snapshots   analytics_report_snapshots[]
  catalog_conflicts            catalog_conflicts[]
  catalog_import_rows          catalog_import_rows[]
  financial_import_rows        financial_import_rows[]
  partner_code_usages          partner_code_usages[]
  promo_links                  promo_links[]
  promo_submissions            promo_submissions[]
  royalty                      royalty[]
  royalty_transactions         royalty_transactions[]
  created_in_catalog_rows      catalog_import_rows[]        @relation("catalog_import_rows_created_release")
  unmatched_analytics_imports  unmatched_analytics_imports[]  @relation("unmatched_analytics_imports_resolved_release")
  user                         user                           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "release_userId_user_id_fk")
  track                        track[]
  playlist_placements          playlist_placements[]

  @@schema("icecream")
}

model sessions {
  session_token String   @id @db.VarChar(128)
  user_id       String   @db.Uuid
  expires       DateTime @db.Timestamptz(6)
  user          user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sessions_user_id_user_id_fk")

  @@schema("icecream")
}

model studio_photos {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  url      String
  studioId String  @db.Uuid
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_photos_studioId_studios_id_fk")

  @@schema("icecream")
}

model studio_stats {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studioId String  @db.Uuid
  name     String
  value    String
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_stats_studioId_studios_id_fk")

  @@schema("icecream")
}

model studio_team {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studioId String  @db.Uuid
  photo    String
  name     String
  position String
  place    String
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_team_studioId_studios_id_fk")

  @@schema("icecream")
}

model studios {
