generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["icecream"]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model accounts {
  user_id            String    @db.Uuid
  type               String    @db.VarChar(16)
  provider           String    @db.VarChar(256)
  provider_ccount_id String    @db.VarChar(256)
  refresh_token      String?   @db.VarChar(1024)
  access_token       String?   @db.VarChar(1024)
  expires_at         DateTime? @db.Timestamp(6)
  token_type         String?   @db.VarChar(256)
  scope              String?   @db.VarChar(256)
  id_token           String?   @db.VarChar(256)
  session_state      String?   @db.VarChar(256)
  user               user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "accounts_user_id_user_id_fk")

  @@ignore
  @@schema("icecream")
}

model analytics {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @db.Uuid
  periodStart          DateTime @db.Timestamp(6)
  periodFinish         DateTime @db.Timestamp(6)
  reportFileUrl        String?
  flourishReportMarkup String
  user                 user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "analytics_userId_user_id_fk")

  @@schema("icecream")
}

model faq {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question String
  answer   String

  @@schema("icecream")
}

model news {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  content   String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  preview   String

  @@schema("icecream")
}

model partner_codes {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                 String                @unique
  label                String?
  active               Boolean               @default(true)
  coversReleasePayment Boolean               @default(true)
  maxUses              Int?
  usedCount            Int                   @default(0)
  expiresAt            DateTime?             @db.Timestamp(6)
  allowedUserId        String?               @db.Uuid
  allowedEmailDomain   String?
  notes                String?
  createdAt            DateTime              @default(now()) @db.Timestamp(6)
  updatedAt            DateTime              @updatedAt @db.Timestamp(6)
  createdByAdminId     String?               @db.Uuid
  allowedUser          user?                 @relation("partner_codes_allowed_user", fields: [allowedUserId], references: [id], onDelete: SetNull)
  createdByAdmin       user?                 @relation("partner_codes_created_by_admin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  usages               partner_code_usages[]

  @@schema("icecream")
}

model orders {
  id             String     @id @db.Uuid
  createdAt      DateTime?  @default(now()) @db.Timestamp(6)
  userId         String     @db.Uuid
  type           order_type
  metadata       Json
  confirmed      Boolean    @default(false)
  payment_status String     @default("pending_payment")
  completed_at   DateTime?  @db.Timestamp(6)
  user           user       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "orders_userId_user_id_fk")

  @@schema("icecream")
}

model payment_methods {
  id        String  @id @db.Uuid
  userId    String  @db.Uuid
  metadata  Json
  isDefault Boolean @default(false)
  user      user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "payment_methods_userId_user_id_fk")

  @@schema("icecream")
}

model payouts {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  confirmed     Boolean?  @default(false)
  recieverName  String?
  amount        Float?
  accountNumber String?
  user          user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "payouts_userId_user_id_fk")

  @@schema("icecream")
}

model promo_links {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortName  String
  releaseId  String       @db.Uuid
  release    release      @relation(fields: [releaseId], references: [id], onDelete: Cascade, map: "promo_links_releaseId_release_id_fk")
  promo_urls promo_urls[]

  @@schema("icecream")
}

model promo_urls {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url         String
  promoLinkId String?      @db.Uuid
  promo_links promo_links? @relation(fields: [promoLinkId], references: [id], onDelete: Cascade, map: "promo_urls_promoLinkId_promo_links_id_fk")

  @@schema("icecream")
}

model release {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  preview                      String
  title                        String
  date                         DateTime                       @db.Timestamp(6)
  upc                          String?
  userId                       String                         @db.Uuid
  language                     String
  subtitle                     String?
  performer                    String?
  feat                         String?
  remixer                      String?
  genre                        String
  labelName                    String?
  startDate                    DateTime                       @db.Timestamp(6)
  preorderDate                 DateTime                       @db.Timestamp(6)
  platforms                    Json?
  area                         Json?
  type                         release_type
  confirmed                    Boolean                        @default(false)
  rejectReason                 String?
  status                       verification_status            @default(moderating)
  roles                        Json?
  moderatorComment             String?
  earlyStartInRussia           Boolean?
  realTimeDelivery             Boolean?
  yandexSoonNewRelease         DateTime?                      @db.Timestamp(6)
  analytics_daily_summaries    analytics_daily_summaries[]
  analytics_platform_summaries analytics_platform_summaries[]
  analytics_report_snapshots   analytics_report_snapshots[]
  partner_code_usages          partner_code_usages[]
  promo_links                  promo_links[]
  unmatched_analytics_imports  unmatched_analytics_imports[]  @relation("unmatched_analytics_imports_resolved_release")
  user                         user                           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "release_userId_user_id_fk")
  track                        track[]

  @@schema("icecream")
}

model sessions {
  session_token String   @id @db.VarChar(128)
  user_id       String   @db.Uuid
  expires       DateTime @db.Timestamptz(6)
  user          user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sessions_user_id_user_id_fk")

  @@schema("icecream")
}

model studio_photos {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  url      String
  studioId String  @db.Uuid
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_photos_studioId_studios_id_fk")

  @@schema("icecream")
}

model studio_stats {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studioId String  @db.Uuid
  name     String
  value    String
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_stats_studioId_studios_id_fk")

  @@schema("icecream")
}

model studio_team {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studioId String  @db.Uuid
  photo    String
  name     String
  position String
  place    String
  studios  studios @relation(fields: [studioId], references: [id], onDelete: Cascade, map: "studio_team_studioId_studios_id_fk")

  @@schema("icecream")
}

model studios {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  logo          String
  name          String
  rating        Float           @default(0) @db.Real
  address       String
  description   String?
  background    String?
  annotation    String?
  lattitude     Float?
  longitude     Float?
  contact_url   String?
  studio_photos studio_photos[]
  studio_stats  studio_stats[]
  studio_team   studio_team[]

  @@schema("icecream")
}

model track {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  releaseId                  String    @db.Uuid
  title                      String
  subtitle                   String?
  isrc                       String?
  partner_code               String?
  roles                      Json?
  preview_start              String
  instant_gratification_date DateTime? @db.Timestamp(6)
  focus                      Boolean   @default(false)
  explicit                   Boolean   @default(false)
  live                       Boolean   @default(false)
  cover                      Boolean   @default(false)
  remix                      Boolean   @default(false)
  instrumental               Boolean   @default(false)
  language                   String
  text                       String?
  track                      String
  text_sync                  String?
  ringtone                   String?
  video                      String?
  author_rights              String
  video_shot                 String?
  index                      Int       @db.SmallInt
  release                    release   @relation(fields: [releaseId], references: [id], onDelete: Cascade, map: "track_releaseId_release_id_fk")

  @@schema("icecream")
}

model partner_code_usages {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerCodeId String        @db.Uuid
  userId        String        @db.Uuid
  releaseId     String        @db.Uuid
  codeSnapshot  String
  createdAt     DateTime      @default(now()) @db.Timestamp(6)
  partnerCode   partner_codes @relation(fields: [partnerCodeId], references: [id], onDelete: Cascade, map: "partner_code_usages_partnerCodeId_partner_codes_id_fk")
  release       release       @relation(fields: [releaseId], references: [id], onDelete: Cascade, map: "partner_code_usages_releaseId_release_id_fk")
  user          user          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "partner_code_usages_userId_user_id_fk")

  @@unique([partnerCodeId, releaseId])
  @@schema("icecream")
}

model user {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                         String
  email                        String                         @unique(map: "user_email_unique")
  emailVerified                DateTime?                      @db.Timestamp(6)
  avatar                       String?
  password                     String?
  verificationToken            String?
  resetPasswordToken           String?
  isVerifiedAuthor             Boolean                        @default(false)
  isAdmin                      Boolean                        @default(false)
  isSubscribed                 Boolean                        @default(false)
  subscribeLevel               subscribe_level?
  expiresAt                    DateTime?                      @db.Timestamp(6)
  freeReleases                 Float                          @default(0)
  balance                      Float                          @default(0)
  aiTokenBalance               Int                            @default(0)
  aiPendingTokenBalance        Int                            @default(0)
  aiMonthlyBonusLastGrantedAt  DateTime?                      @db.Timestamp(6)
  birthDate                    DateTime?                      @db.Timestamp(6)
  country                      String?
  label                        String?
  personalSiteUrl              String?
  telegram                     String?
  vk                           String?
  whatsup                      String?
  viber                        String?
  accounts                     accounts[]                     @ignore
  analytics                    analytics[]
  analytics_daily_summaries    analytics_daily_summaries[]
  analytics_import_jobs        analytics_import_jobs[]        @relation("analytics_import_jobs_created_by_admin")
  analytics_platform_summaries analytics_platform_summaries[]
  analytics_report_snapshots   analytics_report_snapshots[]
  ai_generations               ai_generations[]
  ai_chat_threads              ai_chat_threads[]
  ai_chat_messages             ai_chat_messages[]
  ai_token_transactions        ai_token_transactions[]
  ai_user_notifications        ai_user_notifications[]
  ai_uploads                   ai_uploads[]
  orders                       orders[]
  partnerCodeUsages            partner_code_usages[]
  partnerCodesAllowed          partner_codes[]                @relation("partner_codes_allowed_user")
  partnerCodesCreated          partner_codes[]                @relation("partner_codes_created_by_admin")
  payment_methods              payment_methods[]
  payouts                      payouts[]
  release                      release[]
  sessions                     sessions[]
  unmatched_analytics_imports  unmatched_analytics_imports[]  @relation("unmatched_analytics_imports_resolved_by_admin")
  verification                 verification[]
  verification_tokens          verification_tokens[]

  @@schema("icecream")
}

model ai_studio_system_state {
  id           Int       @id @default(1)
  status       String    @default("preparing")
  activated_at DateTime? @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)

  @@schema("icecream")
}

model ai_models {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String           @unique
  name              String
  provider          String
  section           String
  input_type        String?
  supports_image    Boolean          @default(false)
  supports_audio    Boolean          @default(false)
  supports_video    Boolean          @default(false)
  base_cost_usd     Float            @default(0)
  markup_percent    Float            @default(0)
  price_tokens      Int              @default(0)
  billing_type      String           @default("generation")
  parameters_schema Json?
  active            Boolean          @default(true)
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @updatedAt @db.Timestamp(6)
  generations       ai_generations[]

  @@schema("icecream")
}

model ai_generations {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String     @db.Uuid
  ai_model_id   String?    @db.Uuid
  section       String
  model_code    String
  prompt        String
  input_files   Json?
  parameters    Json?
  cost_tokens   Int        @default(0)
  status        String     @default("queued")
  result_url    String?
  error_message String?
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  updated_at    DateTime   @updatedAt @db.Timestamp(6)
  user          user       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_model      ai_models? @relation(fields: [ai_model_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([section, status])
  @@schema("icecream")
}

model ai_uploads {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  section     String
  file_name   String
  storage_key String
  mime_type   String
  size_bytes  Int
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @updatedAt @db.Timestamp(6)
  user        user     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@schema("icecream")
}

model ai_chat_threads {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String             @db.Uuid
  title           String
  model_code      String
  last_message_at DateTime?          @db.Timestamp(6)
  created_at      DateTime           @default(now()) @db.Timestamp(6)
  updated_at      DateTime           @updatedAt @db.Timestamp(6)
  user            user               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages        ai_chat_messages[]

  @@index([user_id, updated_at])
  @@index([user_id, last_message_at])
  @@schema("icecream")
}

model ai_chat_messages {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id  String          @db.Uuid
  user_id    String          @db.Uuid
  role       String
  content    String
  model_code String?
  created_at DateTime        @default(now()) @db.Timestamp(6)
  thread     ai_chat_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  user       user            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([thread_id, created_at])
  @@index([user_id, created_at])
  @@schema("icecream")
}

model ai_token_packages {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String   @unique
  name         String
  token_amount Int
  bonus_tokens Int      @default(0)
  price_rub    Float
  active       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @updatedAt @db.Timestamp(6)

  @@schema("icecream")
}

model ai_token_transactions {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  package_code  String?
  type          String
  amount_tokens Int
  amount_rub    Float?
  balance_after Int
  generation_id String?  @db.Uuid
  description   String?
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamp(6)
  user          user     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@schema("icecream")
}

model ai_user_notifications {
  id         String    @id
  user_id    String    @db.Uuid
  kind       String    @default("info")
  title      String
  message    String
  cta_label  String?
  cta_href   String?
  created_at DateTime  @default(now()) @db.Timestamp(6)
  read_at    DateTime? @db.Timestamp(6)
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@schema("icecream")
}

model verification {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String              @db.Uuid
  firstName           String
  middleName          String
  lastName            String
  birthDate           DateTime            @db.Timestamp(6)
  birthPlace          String
  tel                 String
  passSeries          String
  passNum             String
  getDate             DateTime            @db.Timestamp(6)
  givenBy             String
  subunitCode         String
  registrationAddress String
  accountNumber       String
  bankName            String
  status              verification_status @default(moderating)
  rejectReason        String?
  contract            String              @default("")
  user                user                @relation(fields: [userId], references: [id], onDelete: Cascade, map: "verification_userId_user_id_fk")

  @@schema("icecream")
}

model verification_tokens {
  user_id String      @db.Uuid
  token   String      @id
  expires DateTime    @db.Timestamp(6)
  type    token_types
  user    user        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "verification_tokens_user_id_user_id_fk")

  @@schema("icecream")
}

model analytics_report_snapshots {
  id               String   @id
  user_id          String   @db.Uuid
  release_id       String   @db.Uuid
  upc              String
  report_date      DateTime @db.Timestamp(3)
  period_days      Int      @default(30)
  country          String
  platform         String?
  streams          Int
  pay_streams      Int
  track_name       String?
  artist_name      String?
  album_name       String?
  source_file_name String
  created_at       DateTime @default(now()) @db.Timestamp(3)
  updated_at       DateTime @db.Timestamp(3)
  user             user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_report_snapshots_user_id_fkey")
  release          release  @relation(fields: [release_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_report_snapshots_release_id_fkey")

  @@unique([release_id, report_date, country, platform], map: "ars_release_date_country_platform_uniq")
  @@index([user_id, report_date], map: "analytics_report_snapshots_user_id_report_date_idx")
  @@index([release_id, report_date], map: "analytics_report_snapshots_release_id_report_date_idx")
  @@index([upc], map: "analytics_report_snapshots_upc_idx")
  @@index([country], map: "analytics_report_snapshots_country_idx")
  @@index([platform], map: "analytics_report_snapshots_platform_idx")
  @@schema("icecream")
}

model analytics_daily_summaries {
  id                String   @id
  user_id           String   @db.Uuid
  release_id        String?  @db.Uuid
  report_date       DateTime @db.Timestamp(3)
  total_streams     Int
  total_pay_streams Int
  countries_count   Int      @default(0)
  top_country       String?
  releases_count    Int      @default(0)
  top_platform      String?
  platforms_count   Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamp(3)
  updated_at        DateTime @db.Timestamp(3)
  user              user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_daily_summaries_user_id_fkey")
  release           release? @relation(fields: [release_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_daily_summaries_release_id_fkey")

  @@unique([user_id, release_id, report_date], map: "analytics_daily_summaries_user_id_release_id_report_date_key")
  @@index([user_id, report_date], map: "analytics_daily_summaries_user_id_report_date_idx")
  @@index([release_id, report_date], map: "analytics_daily_summaries_release_id_report_date_idx")
  @@schema("icecream")
}

model analytics_platform_summaries {
  id             String   @id
  user_id        String   @db.Uuid
  release_id     String?  @db.Uuid
  report_date    DateTime @db.Timestamp(3)
  platform       String
  streams        Int
  pay_streams    Int
  share_percent  Decimal  @default(0) @db.Decimal(7, 3)
  change_percent Decimal? @db.Decimal(7, 3)
  created_at     DateTime @default(now()) @db.Timestamp(3)
  updated_at     DateTime @db.Timestamp(3)
  user           user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_platform_summaries_user_id_fkey")
  release        release? @relation(fields: [release_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_platform_summaries_release_id_fkey")

  @@unique([user_id, release_id, report_date, platform], map: "aps_user_release_date_platform_uniq")
  @@index([user_id, report_date], map: "analytics_platform_summaries_user_id_report_date_idx")
  @@index([release_id, report_date], map: "analytics_platform_summaries_release_id_report_date_idx")
  @@index([platform], map: "analytics_platform_summaries_platform_idx")
  @@schema("icecream")
}

model analytics_import_jobs {
  id                          String                        @id
  source_file_name            String
  stored_file_path            String?
  report_date                 DateTime                      @db.Timestamp(3)
  status                      AnalyticsImportJobStatus      @default(PENDING)
  total_rows                  Int                           @default(0)
  imported_rows               Int                           @default(0)
  matched_rows                Int                           @default(0)
  unmatched_rows              Int                           @default(0)
  affected_users_count        Int                           @default(0)
  affected_releases_count     Int                           @default(0)
  platforms_count             Int                           @default(0)
  rows_with_unknown_platform  Int                           @default(0)
  top_platform                String?
  error_message               String?
  started_at                  DateTime?                     @db.Timestamp(3)
  finished_at                 DateTime?                     @db.Timestamp(3)
  created_by_admin_id         String                        @db.Uuid
  created_at                  DateTime                      @default(now()) @db.Timestamp(3)
  updated_at                  DateTime                      @db.Timestamp(3)
  user                        user                          @relation("analytics_import_jobs_created_by_admin", fields: [created_by_admin_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "analytics_import_jobs_created_by_admin_id_fkey")
  unmatched_analytics_imports unmatched_analytics_imports[]

  @@index([status, created_at], map: "analytics_import_jobs_status_created_at_idx")
  @@index([report_date], map: "analytics_import_jobs_report_date_idx")
  @@schema("icecream")
}

model unmatched_analytics_imports {
  id                   String                 @id
  upc                  String
  track_name           String?
  artist_name          String?
  album_name           String?
  country              String
  streams              Int
  pay_streams          Int
  source_file_name     String
  report_date          DateTime               @db.Timestamp(3)
  reason               String
  import_job_id        String?
  resolved             Boolean                @default(false)
  resolved_at          DateTime?              @db.Timestamp(3)
  resolved_by_admin_id String?                @db.Uuid
  resolved_release_id  String?                @db.Uuid
  created_at           DateTime               @default(now()) @db.Timestamp(3)
  import_job           analytics_import_jobs? @relation(fields: [import_job_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_import_job_id_fkey")
  user                 user?                  @relation("unmatched_analytics_imports_resolved_by_admin", fields: [resolved_by_admin_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_resolved_by_admin_id_fkey")
  release              release?               @relation("unmatched_analytics_imports_resolved_release", fields: [resolved_release_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "unmatched_analytics_imports_resolved_release_id_fkey")

  @@index([report_date], map: "unmatched_analytics_imports_report_date_idx")
  @@index([upc], map: "unmatched_analytics_imports_upc_idx")
  @@index([resolved, report_date], map: "unmatched_analytics_imports_resolved_report_date_idx")
  @@schema("icecream")
}

